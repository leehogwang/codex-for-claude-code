#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/claude-proxy-common.sh"

REAL_CLAUDE="$(resolve_real_claude)"
HAIKU_MODEL="${HAIKU_MODEL:-codex-haiku(xhigh)}"

if should_passthrough_to_claude "$@"; then
  exec "$REAL_CLAUDE" "$@"
fi

ensure_proxy_running
require_provider_auth codex
require_provider_auth claude
load_proxy_env

export ANTHROPIC_DEFAULT_HAIKU_MODEL="$HAIKU_MODEL"
export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="GPT-5.4 via Codex"
export ANTHROPIC_DEFAULT_HAIKU_MODEL_DESCRIPTION="Haiku alias routed through CLIProxyAPI to GPT-5.4"

exec "$REAL_CLAUDE" "$@"
