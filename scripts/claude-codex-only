#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/claude-proxy-common.sh"

REAL_CLAUDE="$(resolve_real_claude)"
HAIKU_MODEL="${HAIKU_MODEL:-codex-haiku(medium)}"
SONNET_MODEL="${SONNET_MODEL:-codex-sonnet(high)}"
OPUS_MODEL="${OPUS_MODEL:-codex-opus(xhigh)}"

if should_passthrough_to_claude "$@"; then
  exec "$REAL_CLAUDE" "$@"
fi

ensure_proxy_running
require_provider_auth codex
load_proxy_env

export ANTHROPIC_MODEL="$SONNET_MODEL"

export ANTHROPIC_DEFAULT_HAIKU_MODEL="$HAIKU_MODEL"
export ANTHROPIC_DEFAULT_HAIKU_MODEL_NAME="GPT-5.4 Codex Haiku"
export ANTHROPIC_DEFAULT_HAIKU_MODEL_DESCRIPTION="Haiku slot routed through CLIProxyAPI to GPT-5.4 with Codex"

export ANTHROPIC_DEFAULT_SONNET_MODEL="$SONNET_MODEL"
export ANTHROPIC_DEFAULT_SONNET_MODEL_NAME="GPT-5.4 Codex Sonnet"
export ANTHROPIC_DEFAULT_SONNET_MODEL_DESCRIPTION="Sonnet slot routed through CLIProxyAPI to GPT-5.4 with Codex"

export ANTHROPIC_DEFAULT_OPUS_MODEL="$OPUS_MODEL"
export ANTHROPIC_DEFAULT_OPUS_MODEL_NAME="GPT-5.4 Codex Opus"
export ANTHROPIC_DEFAULT_OPUS_MODEL_DESCRIPTION="Opus slot routed through CLIProxyAPI to GPT-5.4 with Codex"

exec "$REAL_CLAUDE" "$@"
